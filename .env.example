# ============================================================
# ANDROMEDA LITE — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and adjust the values:
#   cp .env.example .env
#
# NEVER commit .env to Git. It's in .gitignore.
# ============================================================

# ── Identity ─────────────────────────────────────────────────
ANDROMEDA_ENVIRONMENT=development
ANDROMEDA_PORT=8000
ANDROMEDA_FRONTEND_URL=http://localhost:5173

# ── Ollama ──────────────────────────────────────────────────
# Docker Compose: http://host.docker.internal:11434
# Local dev (no Docker): http://localhost:11434
ANDROMEDA_OLLAMA_BASE_URL=http://localhost:11434
ANDROMEDA_OLLAMA_TIMEOUT_SECONDS=120

# ── Inference ────────────────────────────────────────────────
ANDROMEDA_DEFAULT_TEMPERATURE=0.7
ANDROMEDA_DEFAULT_MAX_TOKENS=2048

# ── Observability ────────────────────────────────────────────
ANDROMEDA_TELEMETRY_ENABLED=true
ANDROMEDA_TELEMETRY_DB_PATH=data/traces.db
ANDROMEDA_TRACE_HISTORY_LIMIT=200

# ── Paths ────────────────────────────────────────────────────
ANDROMEDA_SPECIALISTS_CONFIG_PATH=../config/specialists.yaml
ANDROMEDA_HARDWARE_POLICIES_PATH=../config/hardware_policies.yaml

# ── Updates ──────────────────────────────────────────────────
# Repositorio de GitHub donde se publican las releases. Andromeda
# comprueba si hay versión nueva (solo lectura, sin enviar datos).
# Cambia esto por tu repo real, ej: pau/andromeda-lite
ANDROMEDA_GITHUB_REPO=YOUR_USER/andromeda-lite

# ── Cloud (opcional, solo para cuentas/Pro) ──────────────────
# URL del servidor de cuentas. Déjalo vacío en Lite: las cuentas
# no son necesarias y la app funciona 100% local sin esto.
# ANDROMEDA_CLOUD_URL=https://tu-servidor.fly.dev
